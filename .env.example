# Copia este archivo como .env y completa solo los servicios que vayas a usar.
# Nunca subas .env a Git ni compartas sus valores.

# Proveedor principal: gemini, openrouter u ollama
AI_PROVIDER=openrouter
GEMINI_API_KEY=
OPENROUTER_API_KEY=
# Modelo de OpenRouter (opcional, tiene un valor por defecto gratuito)
#OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Ollama: IA local gratis, sin internet. Solo si AI_PROVIDER=ollama.
# Requiere la app de Ollama abierta y un modelo descargado (ollama pull llama3.2)
#OLLAMA_URL=http://127.0.0.1:11434
#OLLAMA_MODEL=llama3.2

# Servicios opcionales
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
ELEVENLABS_API_KEY=

# Voz del asistente: windows (gratis, robótica) o elevenlabs (necesita API key)
#TTS_PROVIDER=windows

# Personalización opcional
BT7274_CITY=Barrancabermeja
